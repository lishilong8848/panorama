{
  "enabled": true,
  "download": {
    "template_name": "交接班日志（李世龙）",
    "lookback_minutes": 20,
    "use_shift_window_when_provided": false,
    "shift_windows": {
      "day": {
        "start": "08:00:00",
        "end": "17:00:00"
      },
      "night": {
        "start": "17:00:00",
        "end_next_day": "08:00:00"
      }
    },
    "scale_label": "5分钟",
    "query_result_timeout_ms": 20000,
    "download_event_timeout_ms": 120000,
    "login_fill_timeout_ms": 5000,
    "menu_visible_timeout_ms": 20000,
    "iframe_timeout_ms": 15000,
    "start_end_visible_timeout_ms": 5000,
    "page_refresh_retry_count": 1,
    "max_retries": 2,
    "retry_wait_sec": 2,
    "force_iframe_reopen_each_task": true,
    "parallel_by_building": false,
    "site_start_delay_sec": 1,
    "debug_step_log": true,
    "menu_path": [
      "报表报告",
      "数据查询",
      "即时报表"
    ],
    "export_button_text": "原样导出",
    "time_format": "%Y-%m-%d %H:%M:%S",
    "switch_to_internal_before_download": true
  },
  "template": {
    "source_path": "交接班日志空模板.xlsx",
    "sheet_name": "交接班日志",
    "output_dir": "D:\\QLDownload\\交接班日志输出",
    "file_name_pattern": "{building}_{date}_交接班日志.xlsx",
    "date_format": "%Y%m%d",
    "apply_building_title": true,
    "title_cell": "A1",
    "building_title_pattern": "EA118机房{building_code}栋数据中心交接班日志",
    "building_title_map": {
      "A楼": "EA118机房A栋数据中心交接班日志",
      "B楼": "EA118机房B栋数据中心交接班日志",
      "C楼": "EA118机房C栋数据中心交接班日志",
      "D楼": "EA118机房D栋数据中心交接班日志",
      "E楼": "EA118机房E栋数据中心交接班日志"
    }
  },
  "parsing": {
    "sheet_index": 0,
    "start_row": 4,
    "col_b": 2,
    "col_c": 3,
    "col_d": 4,
    "col_e": 5,
    "forward_fill_b": true,
    "forward_fill_c": true,
    "value_source": "col_e"
  },
  "normalize": {
    "b_extract_regex": "([A-Za-z]-\\d{3})",
    "c_extract_regex": "([A-Za-z]\\d-\\d)",
    "fallback": "blank"
  },
  "chiller_mode": {
    "west_keys": [
      "chiller_mode_1",
      "chiller_mode_2",
      "chiller_mode_3"
    ],
    "east_keys": [
      "chiller_mode_4",
      "chiller_mode_5",
      "chiller_mode_6"
    ],
    "priority_order": [
      "1",
      "2",
      "3",
      "4"
    ],
    "value_map": {
      "1": "制冷",
      "2": "预冷",
      "3": "板换",
      "4": "停机"
    },
    "fallback_mode_text": "停机"
  },
  "missing_policy": "blank",
  "sites": [],
  "alarm_db": {
    "port": 3306,
    "user": "gj",
    "password": "xbrother",
    "database": "fss",
    "table_pattern": "event_{year}_{month:02d}",
    "time_field": "event_time",
    "masked_field": "masked",
    "is_recover_field": "is_recover",
    "accept_description_field": "accept_description",
    "time_field_mode": "auto",
    "charset": "utf8mb4",
    "connect_timeout_sec": 5,
    "read_timeout_sec": 20,
    "write_timeout_sec": 20,
    "host_source": "site_host"
  },
  "template_fixed_fill": {
    "date_cell": "B2",
    "shift_cell": "F2",
    "alarm_total_cell": "B15",
    "alarm_unrecovered_cell": "D15",
    "alarm_accept_desc_cell": "F15",
    "date_text_format": "{year}年{month}月{day}日",
    "shift_text": {
      "day": "白班",
      "night": "夜班"
    },
    "on_alarm_query_fail": {
      "total": "0",
      "unrecovered": "0",
      "accept_desc": "/"
    }
  },
