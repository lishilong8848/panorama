{
  "version": 3,
  "common": {
    "console": {
      "enabled": true,
      "host": "0.0.0.0",
      "port": 18765,
      "auto_open_browser": true,
      "open_browser_delay_sec": 1,
      "ui_theme": "light",
      "log_buffer_size": 5000,
      "enable_sse": true
    },
    "deployment": {
      "role_mode": "internal",
      "last_started_role_mode": "internal",
      "node_label": "内网端"
    },
    "paths": {
      "excel_dir": "D:\\QLDownload",
      "download_save_dir": "D:\\QLDownload",
      "runtime_state_root": ".runtime"
    },
    "internal_source_sites": [],
    "internal_source_cache": {
      "enabled": true,
      "run_on_startup": true,
      "check_interval_sec": 30,
      "hour_bucket_mode": "natural_hour",
      "latest_required": true,
      "history_fill_timeout_sec": 1800,
      "monthly_report_download": {
        "enabled": true,
        "run_time": "01:00:00",
        "retry_interval_sec": 300
      },
      "top5_monthly_report_download": {
        "enabled": true,
        "day_of_month": 2,
        "run_time": "02:00:00",
        "retry_interval_sec": 300
      },
      "daily_source_download": {
        "enabled": true,
        "run_time": "00:30:00",
        "retry_interval_sec": 300,
        "families": [
          "branch_power_family",
          "branch_current_family",
          "branch_switch_family",
          "building_full_cabinet_power_family",
          "air_conditioner_temperature_humidity_family"
        ]
      }
    },
    "shared_bridge": {},
    "feishu_auth": {}
  },
  "features": {
    "alarm_rule_export": {
      "enabled": true,
      "parallel": 5,
      "download_root": "",
      "state_file": ".runtime\\alarm_rule_export\\export_records.json",
      "screenshots_dir": ".runtime\\alarm_rule_export\\screenshots",
      "generate_poll_interval_sec": 86400,
      "export_generate_timeout_ms": 172800000,
      "keep_open_sec": 1,
      "headless": false,
      "scheduler": {
        "enabled": true,
        "auto_start_in_gui": true,
        "day_of_month": 1,
        "run_time": "03:30:00",
        "check_interval_sec": 60,
        "retry_failed_in_same_period": true,
        "retry_interval_sec": 86400,
        "state_file": "alarm_rule_export_scheduler_state.json"
      }
    }
  }
}
