# Split-source layout
# The two endpoint folders are now the maintained source trees. Keep them tracked
# even though broad legacy ignore rules above ignore *.json and tests/ globally.
!/外网端源码/
!/外网端源码/**
!/内网端源码/
!/内网端源码/**

# Still ignore caches, local config, runtime data and generated state inside each endpoint tree.
/外网端源码/**/__pycache__/
/内网端源码/**/__pycache__/
/外网端源码/**/*.py[cod]
/内网端源码/**/*.py[cod]
/外网端源码/.pytest_cache/
/内网端源码/.pytest_cache/
/外网端源码/.pytest_tmp/
/内网端源码/.pytest_tmp/
